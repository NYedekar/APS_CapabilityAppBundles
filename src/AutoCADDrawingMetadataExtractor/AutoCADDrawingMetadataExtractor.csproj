<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- DA engine +25_0 (AutoCAD 2025) headless runtime is .NET 8.
         +26_0 engine silently fails to load any plugin DLL regardless of TFM — use +25_0. -->
    <TargetFramework>net8.0-windows</TargetFramework>
    <AssemblyName>AutoCADDrawingMetadataExtractor</AssemblyName>
    <RootNamespace>AutoCADDrawingMetadataExtractor</RootNamespace>
    <Nullable>enable</Nullable>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <NoWarn>CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- AutoCAD.NET.Core 25.0.0 targets net8.0 — compile-time stub only; DA worker provides the real DLLs. -->
    <PackageReference Include="AutoCAD.NET.Core" Version="25.0.0" ExcludeAssets="runtime" PrivateAssets="all" />
    <!-- System.Text.Json is built into .NET 10 — no external DLL, no ALC resolution issues. -->
  </ItemGroup>

</Project>
