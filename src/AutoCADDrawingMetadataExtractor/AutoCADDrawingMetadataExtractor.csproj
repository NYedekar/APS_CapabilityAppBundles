<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- AutoCAD 2027 (engine +26_0) requires net10.0 — AutoCAD.NET.Core 26.0.0 only supports net10.0. -->
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>AutoCADDrawingMetadataExtractor</AssemblyName>
    <RootNamespace>AutoCADDrawingMetadataExtractor</RootNamespace>
    <Nullable>enable</Nullable>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <NoWarn>CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- AutoCAD.NET.Core: headless/console stub for DA — accoremgd + acdbmgd reference only.
         AutoCAD.NET 25.0.0 has a broken dep on AutoCAD.NET.Core 25.0.0-V058 (not on NuGet). -->
    <PackageReference Include="AutoCAD.NET.Core" Version="26.0.0" ExcludeAssets="runtime" PrivateAssets="all" />
    <!-- System.Text.Json is built into .NET 10 — no external DLL, no ALC resolution issues. -->
  </ItemGroup>

</Project>
