<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- AutoCAD 2024+ (engine +24, +25) runs on .NET 8; net48 is for 2022/2023 only. -->
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>AutoCADDrawingMetadataExtractor</AssemblyName>
    <RootNamespace>AutoCADDrawingMetadataExtractor</RootNamespace>
    <Nullable>enable</Nullable>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <NoWarn>CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- AutoCAD .NET stubs — ExcludeAssets=runtime so DLLs are NOT copied to output;
         accoreconsole.exe provides them at runtime inside the DA engine. -->
    <PackageReference Include="AutoCAD.NET" Version="25.0.0.0" ExcludeAssets="runtime" PrivateAssets="all" />
    <!-- Newtonsoft.Json MUST be in output — DA engine does not provide it. -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

</Project>
