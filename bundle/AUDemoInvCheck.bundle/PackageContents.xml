<?xml version="1.0" encoding="utf-8" ?>
<!-- ════════════════════════════════════════════════════════════════════════════
     APS DA — Inventor AppBundle manifest (PackageContents.xml template)

     VERIFIED, shipped green: copied from
     bundle/InventorBOMExtractor.bundle/PackageContents.xml in
     APS_CapabilityAppBundles.

     CRITICAL RULES:
     - Platform="Inventor" is required for Inventor DA bundles.
     - ModuleName MUST point to the .Inventor.addin manifest, not the DLL directly.
     - ProductCode uses the SAME GUID as ClassId/ClientId in App.Inventor.addin
       (E7450546-08F5-42AC-80D0-F21812AD05AD) — this is the pattern the real InventorBOMExtractor
       bundle ships (all three collapse to one GUID). Use a FRESH GUID
       (run: uuidgen) for a new bundle.
     - Both LoadOnAutoCADStartup and LoadOnCommandInvocation are False in the
       real bundle (Inventor plugins are activated differently from AutoCAD's
       command-invocation model) — keep them False unless you have a verified
       reason to change them.

     REPLACE: AUDemoInvCheck, E7450546-08F5-42AC-80D0-F21812AD05AD.
     ════════════════════════════════════════════════════════════════════════════ -->
<ApplicationPackage SchemaVersion="1.0"
                    Version="1.0"
                    ProductCode="{E7450546-08F5-42AC-80D0-F21812AD05AD}"
                    Name="AUDemoInvCheck"
                    Description="One-line description of what this bundle does."
                    Author="APS Team">
  <CompanyDetails Name="APS" Url="" Email="" />
  <Components>
    <!-- Platform="Inventor" is required for Inventor DA bundles -->
    <RuntimeRequirements OS="Win64" Platform="Inventor" />
    <!-- ModuleName must point to the .Inventor.addin manifest, not the DLL directly -->
    <ComponentEntry AppName="AUDemoInvCheck"
                    ModuleName="./Contents/AUDemoInvCheck.Inventor.addin"
                    AppDescription="plugin description"
                    LoadOnAutoCADStartup="False"
                    LoadOnCommandInvocation="False" />
  </Components>
</ApplicationPackage>
