<?xml version="1.0" encoding="utf-8" ?>
<ApplicationPackage SchemaVersion="1.0"
                    AutodeskProduct="Revit"
                    Name="RevitExtractor"
                    Description="Extracts model data (rooms, walls, floors, elements, project info) to a JSON report."
                    AppVersion="1.0.0"
                    SupportedLocales="Enu"
                    ProductType="Application"
                    Author="APS Team">

  <CompanyDetails Name="APS" Email="" Url="" />

  <RuntimeRequirements OS="Win64" Platform="Revit" SeriesMin="R2024" SeriesMax="R2024" />

  <Components Description="RevitExtractor core plugin">
    <!--
      ModuleName: the DLL APS loads.
      AppName:    must match the IExternalDBApplication class assembly name.
    -->
    <RuntimeRequirements OS="Win64" Platform="Revit" SeriesMin="R2024" SeriesMax="R2024" />
    <ComponentEntry ModuleName="./RevitExtractor.dll"
                    AppName="RevitExtractor"
                    Version="1.0.0"
                    LoadOnRevitStartup="True" />
  </Components>

</ApplicationPackage>
