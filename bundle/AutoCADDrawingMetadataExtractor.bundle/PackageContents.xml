<?xml version="1.0" encoding="utf-8" ?>
<!-- Structure mirrors the official Autodesk DA-for-AutoCAD sample
     (Autodesk-Forge/learn.forge.designautomation, UpdateDWGParam.bundle), which is
     known to load under accoreconsole. Deliberately MINIMAL:
       * Version + ProductCode present (the sample has both).
       * NO SupportedLocales — that attribute makes the autoloader skip the bundle
         when the DA worker locale doesn't match the exact string, which produced a
         silent "Unknown command" with no load and no Initialize.
       * NO AutodeskProduct / ProductType / AppVersion extras.
       * Both LoadOnCommandInvocation and LoadOnAutoCADStartup = True, as the sample. -->
<ApplicationPackage SchemaVersion="1.0"
                    Version="1.0"
                    ProductCode="{6FF48A6F-247A-480B-BE83-4C9AB098F03D}"
                    Name="AutoCADDrawingMetadataExtractor"
                    Description="Extracts all DWG metadata (summary info, layers, blocks, layouts, entity counts, symbol tables) to JSON."
                    Author="APS Team">

  <CompanyDetails Name="APS" Url="" Email="" />

  <Components>
    <RuntimeRequirements OS="Win64" Platform="AutoCAD" />
    <ComponentEntry AppName="AutoCADDrawingMetadataExtractor"
                    ModuleName="./Contents/AutoCADDrawingMetadataExtractor.dll"
                    AppDescription="DWG metadata extraction plugin"
                    LoadOnCommandInvocation="True"
                    LoadOnAutoCADStartup="True">
      <Commands GroupName="MetadataExtractorCommands">
        <Command Global="EXTRACTDWGMETADATA" Local="EXTRACTDWGMETADATA" />
        <Command Global="EXTRACTALLDRAWINGMETADATA" Local="EXTRACTALLDRAWINGMETADATA" />
      </Commands>
    </ComponentEntry>
  </Components>

</ApplicationPackage>
