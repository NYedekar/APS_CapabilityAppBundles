<?xml version="1.0" encoding="utf-8" ?>
<!-- ════════════════════════════════════════════════════════════════════════════
     APS DA — AutoCAD AppBundle manifest (PackageContents.xml template)

     Structure mirrors the official Autodesk DA-for-AutoCAD sample
     (Autodesk-Forge/learn.forge.designautomation, UpdateDWGParam.bundle), which is
     known to load under accoreconsole. Deliberately MINIMAL:
       * Version + ProductCode present (the sample has both).
       * NO SupportedLocales — that attribute makes the autoloader SKIP the bundle
         when the DA worker locale doesn't match the exact string, producing a
         silent "Unknown command" with no load and no Initialize. DO NOT ADD IT.
       * NO AutodeskProduct / ProductType / AppVersion extras.
       * Both LoadOnCommandInvocation AND LoadOnAutoCADStartup = True, as the sample.

     REPLACE tokens:
       AutoCADTitleBlockUpdater   e.g. AutoCADLayerReport      (== AssemblyName, == .dll name)
       {2FEC944B-31D6-45F8-9D64-15A1DC865A1F}  a FRESH GUID in braces, e.g. {NEW-GUID-HERE}  (uuidgen)
       AutoCADTitleBlockUpdaterCommands    e.g. LayerReportCommands     (any unique group id)
       __CMD_*__         your AutoCAD command verbs (UPPERCASE)
     ════════════════════════════════════════════════════════════════════════════ -->
<ApplicationPackage SchemaVersion="1.0"
                    Version="1.0"
                    ProductCode="{2FEC944B-31D6-45F8-9D64-15A1DC865A1F}"
                    Name="AutoCADTitleBlockUpdater"
                    Description="Reads and updates DWG title-block attributes (Revision, Date, Sheet, Project, ...) across paper-space layouts. Two modes on one verb: extract schema, or update from a changes payload and save the drawing."
                    Author="APS Team">

  <CompanyDetails Name="APS" Url="" Email="" />

  <Components>
    <RuntimeRequirements OS="Win64" Platform="AutoCAD" />
    <ComponentEntry AppName="AutoCADTitleBlockUpdater"
                    ModuleName="./Contents/AutoCADTitleBlockUpdater.dll"
                    AppDescription="Title-block attribute extract/update plugin"
                    LoadOnCommandInvocation="True"
                    LoadOnAutoCADStartup="True">
      <Commands GroupName="AutoCADTitleBlockUpdaterCommands">
        <Command Global="APSTITLEBLOCK" Local="APSTITLEBLOCK" />
        <!-- add more <Command .../> lines as needed -->
      </Commands>
    </ComponentEntry>
  </Components>

</ApplicationPackage>
